# ─────────────────────────────────────────────────────────────
# Keystatic — 儲存模式切換
# 不設 = local（dev 預設，直接寫本機檔案）。
# 設成 'github' = github 模式（production，以及第一次建立 GitHub App 時）。
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_KEYSTATIC_STORAGE=

# ─────────────────────────────────────────────────────────────
# Keystatic — GitHub storage 憑證（僅 github 模式需要）
# 這四個值會在你跑「Create GitHub App」流程後自動產生，
# 請複製到 .env.local（本機）與 Vercel 環境變數（production）。
# ─────────────────────────────────────────────────────────────
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# 既有（非 Keystatic）
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
